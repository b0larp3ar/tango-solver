{
  "manifest_version": 3,

  "name": "LinkedIn Tango Solver",

  "version": "1.0",

  "permissions": [
    "activeTab"
  ],

  "host_permissions": [
    "https://www.linkedin.com/*"
  ],

  "content_scripts": [
    {
      "matches": [
        "https://www.linkedin.com/*"
      ],

      "js": [
        "main.js"
      ]
    }
  ],

  "action": {
    "default_popup": "popup.html",

    "default_icon": {
      "16": "icon16.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  },

  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  }
}